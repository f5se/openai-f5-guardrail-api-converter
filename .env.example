# =========================
# 基础运行配置
# =========================
HOST=0.0.0.0
PORT=8080

# 上游 F5 Guardrail chat/completions 完整 URL（含路径）
UPSTREAM_BASE_URL=https://www.calypsoai.app/openai/your-route/chat/completions

# =========================
# HTTP 客户端连接池与超时
# =========================
HTTP_TIMEOUT_CONNECT=30
HTTP_TIMEOUT_READ=600
HTTP_TIMEOUT_WRITE=60
HTTP_TIMEOUT_POOL=5
MAX_CONNECTIONS=200
MAX_KEEPALIVE_CONNECTIONS=50

# =========================
# OpenAI models 占位接口
# =========================
MODELS_LIST_ID=placeholder-model
MODELS_LIST_OWNED_BY=proxy

# =========================
# Dify Moderation 配置
# =========================
# Dify 扩展调用本服务时的鉴权 token（必填）
DIFY_MODERATION_TOKEN=replace_with_your_dify_token

# F5 scans 接口与鉴权
F5_SCANS_URL=https://calypsoai.app/backend/v1/scans
F5_SCANS_API_KEY=replace_with_your_f5_scans_api_key

# 命中 flagged 时，按扩展点返回的预设文案
MODERATION_INPUT_BLOCK_MESSAGE=请求经F5 Guardrail检查存在违规。
MODERATION_OUTPUT_BLOCK_MESSAGE=响应经F5 Guardrail检查存在违规。

# =========================
# 调试日志
# =========================
# true/1/on/yes 开启详细链路日志；默认关闭
LOG_DEBUG=false

# 日志文件名（写到程序启动目录）
LOG_FILE_NAME=f5api-converter.log
